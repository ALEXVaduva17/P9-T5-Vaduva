# ============================================================
# Fitness Center Management System — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ── PostgreSQL ──
POSTGRES_USER=fitness_user
POSTGRES_PASSWORD=fitness_secret_password
POSTGRES_DB=fitness_center_db

# ── Backend ──
# Async connection string used by SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://fitness_user:fitness_secret_password@db:5432/fitness_center_db

# Secret key for JWT / session signing (generate a strong random value)
SECRET_KEY=change-me-to-a-random-secret

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:8000
