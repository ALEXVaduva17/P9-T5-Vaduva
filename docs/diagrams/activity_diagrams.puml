' ══════════════════════════════════════════════════════════════
' ACTIVITY 1 – USER LOGIN
' ══════════════════════════════════════════════════════════════
@startuml Activity 1 - User Login and Authentication
!theme plain
skinparam ActivityBorderColor #336699
skinparam ActivityBackgroundColor #EEF4FF
skinparam ActivityDiamondBorderColor #336699
skinparam ActivityDiamondBackgroundColor #FFF8DC
skinparam ArrowColor #555555
skinparam shadowing false

title Activity 1 – User Login & Authentication

|User|
start
:Navigate to Login Page;
:Enter Email & Password;
:Submit Login Form;

|System|
:Validate Input Format;
if (Input valid?) then (no)
  :Display field-level error;
  stop
else (yes)
endif

:Check account lockout status;
if (Account locked?) then (yes)
  :Return lockout message\nwith remaining lock time;
  stop
else (no)
endif

:Query user by email;
if (User exists?) then (no)
  :Return generic error\n(do not reveal which field);
  stop
else (yes)
endif

:Verify bcrypt password hash;
if (Password matches?) then (no)
  :Increment failed attempt counter;
  if (Attempts >= 5?) then (yes)
    :Lock account for 15 min;
    :Send lockout notification email;
    |Email Provider|
    :Deliver lockout email to user;
    |System|
    :Return lockout message;
    stop
  else (no)
    :Return generic error;
    stop
  endif
else (yes)
endif

:Reset failed attempt counter;
:Issue JWT access token (15 min TTL)\n+ Refresh token (7 days TTL);

|User|
:Redirect to role-appropriate dashboard\n(Admin / Member / Trainer);
stop

@enduml

' ══════════════════════════════════════════════════════════════
' ACTIVITY 2 – MAKE A CLASS RESERVATION
' ══════════════════════════════════════════════════════════════
@startuml Activity 2 - Make a Class Reservation
!theme plain
skinparam ActivityBorderColor #336699
skinparam ActivityBackgroundColor #EEF4FF
skinparam ActivityDiamondBorderColor #336699
skinparam ActivityDiamondBackgroundColor #FFF8DC
skinparam ArrowColor #555555
skinparam shadowing false

title Activity 2 – Make a Class Reservation

|Member|
start
:Navigate to Class Schedule;
:Select a Class;

|System|
:Check member subscription status;
if (Status is 'active'?) then (no)
  :Reject with status explanation\n(restricted / inactive);
  stop
else (yes)
endif

:Check for duplicate reservation;
if (Member already reserved?) then (yes)
  :Return duplicate reservation error;
  stop
else (no)
endif

:Atomically check available spots;
if (Spots available?) then (no)
  |Member|
  :Offer Waitlist option;
  if (Member joins waitlist?) then (yes)
    |System|
    :Record waitlist entry with timestamp;
    :Confirm waitlist position to member;
    stop
  else (no)
    stop
  endif
else (yes)
endif

|System|
:Atomically decrement available spots;
:Create reservation record (status=active);
:Trigger confirmation notification;

|Email Provider|
:Send confirmation email\n(class, trainer, facility, time,\ncancellation link);

|Member|
:View reservation confirmation;
stop

@enduml

' ══════════════════════════════════════════════════════════════
' ACTIVITY 3 – CANCEL A RESERVATION
' ══════════════════════════════════════════════════════════════
@startuml Activity 3 - Cancel a Reservation
!theme plain
skinparam ActivityBorderColor #336699
skinparam ActivityBackgroundColor #EEF4FF
skinparam ActivityDiamondBorderColor #336699
skinparam ActivityDiamondBackgroundColor #FFF8DC
skinparam ArrowColor #555555
skinparam shadowing false

title Activity 3 – Cancel a Reservation

|Member / Admin|
start
:Navigate to Reservation;
:Click Cancel;

|System|
:Display confirmation modal;

|Member / Admin|
:Confirm cancellation;

|System|
:Calculate time until class start;
if (Within 2 hours of class?) then (yes)
  :Flag reservation as\nlate cancellation;
else (no)
endif

:Set reservation status to 'cancelled';
:Record cancellation timestamp;
:Increment available spots;

:Check waitlist for this class;
if (Waitlist has members?) then (yes)
  :Promote first waitlisted member;
  :Set 2-hour confirmation window;
  |Email Provider|
  :Notify promoted member\n(email + optional SMS);
  |System|
  if (Member confirms within 2 hours?) then (yes)
    :Create active reservation\nfor promoted member;
  else (no)
    :Offer spot to next\nwaitlisted member;
  endif
else (no)
endif

|Member / Admin|
:View updated reservation list;
stop

@enduml

' ══════════════════════════════════════════════════════════════
' ACTIVITY 4 – SUBSCRIPTION LIFECYCLE
' ══════════════════════════════════════════════════════════════
@startuml Activity 4 - Subscription Lifecycle
!theme plain
skinparam ActivityBorderColor #336699
skinparam ActivityBackgroundColor #EEF4FF
skinparam ActivityDiamondBorderColor #336699
skinparam ActivityDiamondBackgroundColor #FFF8DC
skinparam ArrowColor #555555
skinparam shadowing false

title Activity 4 – Subscription Lifecycle (Create to Expiry to Renewal)

|Administrator|
start
:Navigate to Member Profile;
:Click Add Subscription;
:Select subscription type & start date;

|System|
:Calculate end date from type duration;
:Check for overlapping active subscription;
if (Overlap exists?) then (yes)
  :Return validation error;
  stop
else (no)
endif

:Display subscription preview\n(dates, pricing breakdown);

|Administrator|
:Confirm subscription;

|System|
:Create subscription record (status=active);
:Update member status to 'active';

|Member|
:Pay online via gateway;

|System|
:Initiate checkout session via Payment Gateway API;

|Payment Gateway|
:Member completes payment;
:Send webhook to system;

|System|
:Verify webhook signature (HMAC-SHA256);
:Record payment (gateway_ref, amount, status=succeeded);

|Email Provider|
:Generate and email PDF receipt;

|System (Scheduler)|
:Daily job runs at midnight;
:Query active subscriptions\nwhere end_date < today;
if (Expired subscriptions found?) then (yes)
  :Set subscription status to 'expired';
  :Set member status to 'restricted';
  |Email Provider|
  :Send expiry notification email;
  |System (Scheduler)|
else (no)
endif

:Query subscriptions expiring in 7 days;
if (Matches found?) then (yes)
  |Email Provider|
  :Send 7-day renewal reminder;
  |System (Scheduler)|
else (no)
endif

:Query subscriptions expiring in 1 day;
if (Matches found?) then (yes)
  |Email Provider|
  :Send 1-day renewal reminder;
  |System (Scheduler)|
else (no)
endif

|Administrator|
:Navigate to expired/restricted member;
:Click Renew Subscription;

|System|
:Pre-populate renewal form\n(same subscription type);
:Set new start = current end + 1 day;
:Create new subscription record;
:Update member status to 'active';

|Administrator|
:Renewal confirmed;
stop

@enduml

' ══════════════════════════════════════════════════════════════
' ACTIVITY 5 – CREATE & MANAGE A TRAINING CLASS
' ══════════════════════════════════════════════════════════════
@startuml Activity 5 - Create and Manage a Training Class
!theme plain
skinparam ActivityBorderColor #336699
skinparam ActivityBackgroundColor #EEF4FF
skinparam ActivityDiamondBorderColor #336699
skinparam ActivityDiamondBackgroundColor #FFF8DC
skinparam ArrowColor #555555
skinparam shadowing false

title Activity 5 – Create and Manage a Training Class

|Administrator|
start
:Navigate to Classes > Add New;
:Fill in class details\n(name, trainer, facility,\nstart/end time, capacity);

|System|
:Validate required fields;
if (Fields complete?) then (no)
  :Highlight missing fields;
  stop
else (yes)
endif

:Check facility for scheduling conflict;
if (Facility already booked\nat overlapping time?) then (yes)
  :Return conflict error;
  stop
else (no)
endif

:Check trainer for scheduling conflict;
if (Trainer has overlapping class?) then (yes)
  :Return conflict error;
  stop
else (no)
endif

:Create class record (status=scheduled);
:Make class visible in member schedule;

|Administrator|
:Optionally edit class later;
if (Capacity reduced?) then (yes)
  |System|
  :Check current active reservations;
  if (New capacity < reservation count?) then (yes)
    :Block save, show warning;
  else (no)
    :Save changes;
    :Notify reserved members\nof time change (if time changed);
    |Email Provider|
    :Send time-change email to all\nreserved members;
  endif
else (no)
  |System|
  :Save changes;
endif

|Administrator|
:Optionally cancel class;

|System|
:Set class status to 'cancelled';
:Cancel all active reservations;

|Email Provider|
:Send cancellation email\nto each affected member\n(within 5 min);

stop

@enduml
